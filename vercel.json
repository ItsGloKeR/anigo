{
  "version": 2,
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/aniwatch-api/(.*)",
      "destination": "https://aniwatchtv.to/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
